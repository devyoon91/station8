<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <title>Workflow Dashboard</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
</head>
<body class="bg-light">
<div class="container mt-5">
    <h1 class="mb-4">Workflow Monitoring Dashboard</h1>
    
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card text-white bg-primary mb-3">
                <div class="card-body">
                    <h5 class="card-title">Total</h5>
                    <p class="card-text fs-2">{{totalCount}}</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-white bg-success mb-3">
                <div class="card-body">
                    <h5 class="card-title">Completed</h5>
                    <p class="card-text fs-2">{{completedCount}}</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-white bg-warning mb-3">
                <div class="card-body">
                    <h5 class="card-title">Running</h5>
                    <p class="card-text fs-2">{{runningCount}}</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-white bg-danger mb-3">
                <div class="card-body">
                    <h5 class="card-title">Failed</h5>
                    <p class="card-text fs-2">{{failedCount}}</p>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <h5 class="card-title mb-4">Workflow Instances</h5>
            <table class="table table-hover">
                <thead class="table-light">
                <tr>
                    <th>ID</th>
                    <th>Workflow Name</th>
                    <th>Status</th>
                    <th>Start Date</th>
                    <th>End Date</th>
                    <th>Actions</th>
                </tr>
                </thead>
                <tbody>
                {{#instances}}
                <tr>
                    <td class="text-truncate" style="max-width: 150px;" title="{{id}}">{{id}}</td>
                    <td>{{workflowName}}</td>
                    <td>
                        <span class="badge {{#statusSt}}bg-{{#equals . 'COMPLETED'}}success{{/equals}}{{#equals . 'RUNNING'}}warning{{/equals}}{{#equals . 'FAILED'}}danger{{/equals}}{{/statusSt}}">
                            {{statusSt}}
                        </span>
                    </td>
                    <td>{{startDt}}</td>
                    <td>{{#endDt}}{{endDt}}{{/endDt}}{{^endDt}}-{{/endDt}}</td>
                    <td>
                        <a href="/workflow/instance/{{id}}" class="btn btn-sm btn-outline-primary">Details</a>
                    </td>
                </tr>
                {{/instances}}
                {{^instances}}
                <tr>
                    <td colspan="6" class="text-center text-muted">No instances found.</td>
                </tr>
                {{/instances}}
                </tbody>
            </table>
        </div>
    </div>
</div>
</body>
</html>
