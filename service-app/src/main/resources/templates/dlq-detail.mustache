<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <title>DLQ Detail</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
</head>
<body class="bg-light">
<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>DLQ Entry Detail</h1>
        <a href="/workflow/dlq" class="btn btn-outline-secondary">← DLQ List</a>
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-sm-3">ID</dt>
                <dd class="col-sm-9">{{entry.id}}</dd>

                <dt class="col-sm-3">Workflow</dt>
                <dd class="col-sm-9">{{entry.workflowName}}</dd>

                <dt class="col-sm-3">Activity</dt>
                <dd class="col-sm-9">{{entry.activityName}}</dd>

                <dt class="col-sm-3">Status</dt>
                <dd class="col-sm-9"><span class="badge bg-secondary">{{entry.dlqStatusSt}}</span></dd>

                <dt class="col-sm-3">Instance ID</dt>
                <dd class="col-sm-9">
                    <a href="/workflow/instance/{{entry.instanceId}}">{{entry.instanceId}}</a>
                </dd>

                <dt class="col-sm-3">Execution ID</dt>
                <dd class="col-sm-9">{{entry.executionId}}</dd>

                <dt class="col-sm-3">Retry Count</dt>
                <dd class="col-sm-9">{{entry.retryCnt}} / {{entry.maxRetryCnt}}</dd>

                <dt class="col-sm-3">Failed At</dt>
                <dd class="col-sm-9">{{entry.failedAtDt}}</dd>

                <dt class="col-sm-3">Registered</dt>
                <dd class="col-sm-9">{{entry.regDt}}</dd>
            </dl>
        </div>
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-header">Error Message</div>
        <div class="card-body">
            <pre class="mb-0">{{entry.errorMessage}}</pre>
        </div>
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-header">Stack Trace</div>
        <div class="card-body">
            <pre class="mb-0" style="max-height: 400px; overflow-y: auto;">{{entry.stackTrace}}</pre>
        </div>
    </div>

    {{#entry.isNew}}
    <div class="d-flex gap-2">
        <form action="/workflow/dlq/{{entry.id}}/requeue" method="post">
            <button type="submit" class="btn btn-success">Requeue</button>
        </form>
        <form action="/workflow/dlq/{{entry.id}}/discard" method="post">
            <button type="submit" class="btn btn-dark">Discard</button>
        </form>
    </div>
    {{/entry.isNew}}
</div>
</body>
</html>
