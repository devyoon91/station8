    { "name": "dashboard",            "title": "대시보드",          "path": "/line/dashboard",         "auth": true,  "viewports": ["desktop", "mobile"] },
    { "name": "definitions",          "title": "라인 정의 목록",    "path": "/line/definitions",       "auth": true },
