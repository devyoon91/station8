    { "name": "schedules",            "title": "스케줄",            "path": "/line/schedules",         "auth": true },
    { "name": "activities",           "title": "액티비티 카탈로그", "path": "/line/activities",        "auth": true },
    { "name": "dlq",                  "title": "DLQ",               "path": "/line/dlq",               "auth": true },
    { "name": "triggers",             "title": "트리거",            "path": "/line/triggers",          "auth": true },
    { "name": "admin-users",          "title": "관리자 · 사용자",   "path": "/admin/users",            "auth": true },
    { "name": "admin-credentials",    "title": "관리자 · 크리덴셜", "path": "/admin/credentials",      "auth": true },
    { "name": "admin-credential-form","title": "크리덴셜 등록",     "path": "/admin/credentials/new",  "auth": true },
    { "name": "admin-datasources",    "title": "관리자 · 데이터소스","path": "/admin/datasources",     "auth": true },
    { "name": "admin-datasource-form","title": "데이터소스 등록",   "path": "/admin/datasources/new",  "auth": true },
    { "name": "admin-plugins",        "title": "관리자 · 플러그인", "path": "/admin/plugins",          "auth": true },
    { "name": "me-password",          "title": "비밀번호 변경",     "path": "/me/password",            "auth": true },
    { "name": "definition-preview",   "title": "라인 정의 미리보기","path": "/line/definitions/{id}",  "auth": true, "resolve": "definition" },
    { "name": "timeline",             "title": "인스턴스 타임라인", "path": "/line/instance/{id}",     "auth": true, "resolve": "instance" }
