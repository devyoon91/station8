# tools/screenshots/.env — 복사해서 .env로 쓰고 값 채우기 (git에 커밋 금지)
# capture.js가 무의존성으로 이 파일을 읽는다.

# 캡처 대상 앱 주소
BASE_URL=http://localhost:8080

# 인증 화면 캡처용 계정 (ADMIN 권장 — 관리자 화면까지 찍으려면)
S8_USER=admin
S8_PASS=

# 로컬 Chrome 경로 (미지정 시 자동 탐색). Windows 예:
# CHROME_PATH=C:/Program Files/Google/Chrome/Application/chrome.exe

# 캡처할 테마 (쉼표 구분). light만 원하면 light
THEMES=light,dark

# 산출물 디렉토리 (기본: ../../docs/assets/screenshots)
# OUT_DIR=
