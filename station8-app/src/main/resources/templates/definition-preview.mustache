<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <title>{{definitionNm}} — Station8 Subway Map</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    <link rel="stylesheet" href="/css/design.css">
</head>
<body>
{{> _nav }}

<div class="swe-container" style="padding-top: var(--space-xxl); padding-bottom: var(--space-section);">

    <div class="swe-flex-between swe-mb-xl">
        <div>
            <a href="/line/definitions" class="swe-mute" style="font-size: 13px;">← Lines</a>
            <h1 class="swe-display-lg" style="margin: var(--space-xs) 0 0;">{{definitionNm}}</h1>
            <p class="swe-body-md swe-mute" style="margin: var(--space-sm) 0 0;">
                v{{versionNo}} · {{nodeCount}} 역 · {{edgeCount}} 트랙
                {{#description}} · {{description}}{{/description}}
            </p>
        </div>
        <div class="swe-row">
            <a href="/line/definitions" class="swe-btn-tertiary">Back</a>
            <a href="/line/builder?id={{definitionId}}" class="swe-btn-tertiary">Edit</a>
            <button type="button" class="swe-btn-primary" onclick="openRunModal()">▶ Run now</button>
        </div>
    </div>

    <!-- #135 — 좌측 stations list 패널 + 우측 노선도 2-col -->
    <div class="swe-preview-layout">
        <aside class="swe-preview-stations-panel">
            <div class="swe-panel-header">Stations</div>
            <div class="swe-panel-body">
                <div class="swe-station-list-search">
                    <input type="text" id="stations-search" placeholder="역 이름 / activity 검색…" aria-label="Stations 검색">
                </div>
                <div class="swe-station-list" id="stations-list">
                    <div class="swe-station-list-empty">Loading…</div>
                </div>
            </div>
        </aside>
        <div class="swe-subway-frame">
            <div id="subway-map"></div>
        </div>
    </div>

    <div id="station-detail" class="swe-card swe-card-tight" style="margin-top: var(--space-lg); display: none;">
        <div class="swe-flex-between swe-mb-xl" style="margin-bottom: var(--space-md);">
            <h3 class="swe-heading-sm" style="margin: 0;" id="station-detail-name">—</h3>
            <button type="button" class="swe-btn-tertiary swe-btn-sm" id="station-detail-close">닫기</button>
        </div>
        <div class="swe-grid swe-grid-2">
            <div>
                <div class="swe-caption swe-mute">Activity</div>
                <div id="station-detail-activity" class="swe-body-md">—</div>
            </div>
            <div>
                <div class="swe-caption swe-mute">Node ID</div>
                <div id="station-detail-id" style="font-family: monospace; font-size: 12px;">—</div>
            </div>
        </div>
        <div style="margin-top: var(--space-md);">
            <div class="swe-caption swe-mute">Input params</div>
            <pre id="station-detail-params" style="margin: var(--space-xs) 0 0; padding: var(--space-md); background: var(--surface-card); border-radius: var(--radius-md); font-size: 12px; overflow-x: auto;">—</pre>
        </div>
    </div>

    <p class="swe-caption-sm" style="margin-top: var(--space-md);">
        ※ 역을 클릭하면 메타데이터(M3). 인스턴스 진행 위치 오버레이는 인스턴스 상세 페이지에서.
    </p>

    {{#runMsg}}
    <div class="swe-card swe-mb-xl" style="margin-top: var(--space-lg); padding: var(--space-md) var(--space-lg); border-left: 4px solid {{#runOk}}var(--accent-green){{/runOk}}{{^runOk}}var(--accent-pink){{/runOk}};">
        <code style="color: var(--ink); font-size: 0.95em;">{{runMsg}}</code>
    </div>
    {{/runMsg}}

    <!-- #133 — 정의 단위 통계 + 최근 실행 -->
    <h2 class="swe-heading-md" style="margin-top: var(--space-section); margin-bottom: var(--space-md);">실행 현황</h2>

    <div class="swe-grid swe-grid-4 swe-mb-xl">
        <div class="swe-stat-card">
            <div class="swe-stat-label">Total runs</div>
            <div class="swe-stat-value">{{statTotal}}</div>
        </div>
        <div class="swe-stat-card">
            <div class="swe-stat-label" style="color: var(--accent-yellow);">Running</div>
            <div class="swe-stat-value">{{statRunning}}</div>
        </div>
        <div class="swe-stat-card">
            <div class="swe-stat-label" style="color: var(--accent-green);">Completed</div>
            <div class="swe-stat-value">{{statCompleted}}</div>
        </div>
        <div class="swe-stat-card">
            <div class="swe-stat-label" style="color: var(--accent-red);">Failed</div>
            <div class="swe-stat-value">{{statFailed}}</div>
        </div>
    </div>

    <div class="swe-flex-between swe-mb-md">
        <h3 class="swe-heading-sm" style="margin: 0;">최근 실행 (최대 10건)</h3>
        {{#hasAnyRun}}
        <a href="{{{dashboardDeepLink}}}" class="swe-btn-tertiary swe-btn-sm">View all in Dashboard →</a>
        {{/hasAnyRun}}
    </div>

    <div class="swe-card" style="padding: 0;">
        <table class="swe-table">
            <thead>
            <tr>
                <th>Instance ID</th>
                <th>Status</th>
                <th>Started</th>
                <th>Ended</th>
                <th>Duration</th>
                <th class="swe-text-right">Action</th>
            </tr>
            </thead>
            <tbody>
            {{#recentRuns}}
            <tr>
                <td title="{{id}}"><code style="font-size: 12px;">{{idShort}}…</code></td>
                <td><span class="swe-badge swe-badge-{{badgeClass}}">{{statusSt}}</span></td>
                <td class="swe-mute">{{#startedAt}}{{startedAt}}{{/startedAt}}{{^startedAt}}—{{/startedAt}}</td>
                <td class="swe-mute">{{#endedAt}}{{endedAt}}{{/endedAt}}{{^endedAt}}—{{/endedAt}}</td>
                <td class="swe-mute">{{duration}}</td>
                <td class="swe-text-right">
                    <a href="/line/instance/{{id}}" class="swe-btn-tertiary swe-btn-sm">Detail</a>
                </td>
            </tr>
            {{/recentRuns}}
            {{^recentRuns}}
            <tr>
                <td colspan="6" style="text-align: center; padding: var(--space-section) 0; color: var(--mute);">
                    아직 실행 기록이 없습니다.
                    <button type="button" class="swe-btn-primary swe-btn-sm" style="margin-left: var(--space-md);" onclick="openRunModal()">▶ Run now</button>
                </td>
            </tr>
            {{/recentRuns}}
            </tbody>
        </table>
    </div>

    {{#canAdmin}}
    <!-- #140 — 권한 관리 (정의의 ADMIN만 노출) -->
    <h2 class="swe-heading-md" style="margin-top: var(--space-section); margin-bottom: var(--space-md);">Permissions</h2>

    {{#aclMsg}}
    <div class="swe-card swe-mb-xl" style="padding: var(--space-md) var(--space-lg); border-left: 4px solid {{#aclOk}}var(--accent-green){{/aclOk}}{{^aclOk}}var(--accent-pink){{/aclOk}};">
        <code style="color: var(--ink); font-size: 0.95em;">{{aclMsg}}</code>
    </div>
    {{/aclMsg}}

    <div class="swe-card swe-mb-xl" style="padding: 0;">
        <table class="swe-table">
            <thead>
                <tr>
                    <th>User</th>
                    <th>Permission</th>
                    <th class="swe-text-right">Action</th>
                </tr>
            </thead>
            <tbody>
                {{#aclEntries}}
                <tr>
                    <td>{{username}}{{#displayNm}} <span class="swe-mute" style="font-size:12px;">— {{displayNm}}</span>{{/displayNm}}</td>
                    <td><span class="swe-badge swe-badge-{{#isAdmin}}danger{{/isAdmin}}{{^isAdmin}}info{{/isAdmin}}">{{permission}}</span></td>
                    <td class="swe-text-right">
                        <form action="/line/definitions/{{definitionId}}/acl/revoke" method="post" style="display:inline;"
                              onsubmit="return confirm('{{username}}의 {{permission}} 권한을 회수합니까?');">
                            {{> _csrf}}
                            <input type="hidden" name="userId" value="{{userId}}">
                            <input type="hidden" name="permission" value="{{permission}}">
                            <button type="submit" class="swe-btn-tertiary swe-btn-sm swe-btn-danger">Revoke</button>
                        </form>
                    </td>
                </tr>
                {{/aclEntries}}
                {{#aclEmpty}}
                <tr>
                    <td colspan="3" style="text-align:center; padding: var(--space-lg) 0; color: var(--mute);">
                        ACL entry가 없습니다 (legacy/open 모드 — 모든 인증된 USER 통과). grant 추가 시 managed로 전환됩니다.
                    </td>
                </tr>
                {{/aclEmpty}}
            </tbody>
        </table>
    </div>

    <div class="swe-card swe-mb-xl" style="padding: var(--space-md) var(--space-lg);">
        <h3 class="swe-heading-sm" style="margin: 0 0 var(--space-md);">Grant permission</h3>
        <form action="/line/definitions/{{definitionId}}/acl/grant" method="post" class="swe-grid swe-grid-3" style="gap: var(--space-md); align-items: end;">
            {{> _csrf}}
            <div>
                <label for="acl-username">Username</label>
                <input type="text" id="acl-username" name="username" class="swe-input" placeholder="alice" required>
            </div>
            <div>
                <label for="acl-permission">Permission</label>
                <select id="acl-permission" name="permission" class="swe-input" required>
                    <option value="READ">READ — 조회 (1차 비범위)</option>
                    <option value="WRITE">WRITE — 정의 수정/삭제</option>
                    <option value="EXECUTE">EXECUTE — 실행 + 인스턴스 제어</option>
                    <option value="SCHEDULE">SCHEDULE — cron 등록/수정</option>
                    <option value="ADMIN">ADMIN — 위 전체 + 권한 관리</option>
                </select>
            </div>
            <div>
                <button type="submit" class="swe-btn-primary swe-w-full">Grant</button>
            </div>
        </form>
        <div class="swe-mute" style="font-size:11px; margin-top: var(--space-md);">
            ADMIN은 다른 권한을 자동 cascade. 같은 USER+권한 조합은 idempotent (중복 grant 무시). 글로벌 ROLE_ADMIN은 ACL 우회.
        </div>
    </div>
    {{/canAdmin}}

</div>

<!-- #133 — Run now 모달 (D6=a) -->
<div id="run-modal-backdrop" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.55); z-index:1000;"></div>
<div id="run-modal" role="dialog" aria-modal="true" aria-labelledby="run-modal-title"
     style="display:none; position:fixed; top:50%; left:50%; transform:translate(-50%, -50%);
            width:520px; max-width:90vw; background:var(--surface); border:1px solid var(--hairline);
            border-radius:var(--radius-lg); padding:var(--space-lg); z-index:1001;">
    <div class="swe-flex-between swe-mb-xl">
        <h3 id="run-modal-title" class="swe-heading-md" style="margin:0;">Run "{{definitionNm}}"</h3>
        <button type="button" class="swe-btn-tertiary swe-btn-sm" onclick="closeRunModal()">✕</button>
    </div>
    <div>
        <label for="run-input-data" style="display:block; font-weight:600; margin-bottom:var(--space-xs);">Input data (JSON, optional)</label>
        <textarea id="run-input-data" rows="6" placeholder='{"date": "2026-05-10"}'
                  style="width:100%; padding:var(--space-sm); background:var(--surface-2); border:1px solid var(--line);
                         color:var(--ink); border-radius:var(--radius-sm); font-family:var(--font-mono); font-size:0.9em;"></textarea>
        <div class="swe-mute" style="font-size:11px; margin-top:var(--space-xs);">
            빈 값 OK — 입력 없이 실행. 본문은 자유 텍스트(액티비티가 직접 파싱). JSON 강제 X.
        </div>
    </div>

    <!-- #134 — Advanced options (collapsed by default) -->
    <details style="margin-top:var(--space-md);">
        <summary style="cursor:pointer; font-weight:600; user-select:none;">Advanced options</summary>
        <div style="margin-top:var(--space-md); display:flex; flex-direction:column; gap:var(--space-md);">
            <div>
                <label for="run-on-failure" style="display:block; font-weight:600; margin-bottom:var(--space-xs);">On failure</label>
                <select id="run-on-failure"
                        style="width:100%; padding:var(--space-sm); background:var(--surface-2); border:1px solid var(--line);
                               color:var(--ink); border-radius:var(--radius-sm); font-size:0.9em;">
                    <option value="CONTINUE" selected>CONTINUE — 활동 실패 시 다른 활동은 계속 (기본)</option>
                    <option value="ABORT">ABORT — 활동 최종 실패 시 인스턴스 즉시 종료</option>
                    <option value="PAUSE_ON_FAILURE">PAUSE_ON_FAILURE — 활동 최종 실패 시 인스턴스 PAUSED (운영자 개입 대기) #148</option>
                </select>
            </div>
            <div>
                <label for="run-runtime-params" style="display:block; font-weight:600; margin-bottom:var(--space-xs);">Runtime params (JSON object, optional)</label>
                <textarea id="run-runtime-params" rows="4" placeholder='{"region": "KR", "tier": "premium"}'
                          style="width:100%; padding:var(--space-sm); background:var(--surface-2); border:1px solid var(--line);
                                 color:var(--ink); border-radius:var(--radius-sm); font-family:var(--font-mono); font-size:0.9em;"></textarea>
                <div class="swe-mute" style="font-size:11px; margin-top:var(--space-xs);">
                    LineContext.runtimeParams()로 활동에 전달되는 string→string 맵. 비워두면 빈 맵.
                </div>
            </div>
            <div>
                <label for="run-webhook" style="display:block; font-weight:600; margin-bottom:var(--space-xs);">Notification webhook URL (optional)</label>
                <input type="text" id="run-webhook" placeholder="https://hooks.example.com/dlq"
                       style="width:100%; padding:var(--space-sm); background:var(--surface-2); border:1px solid var(--line);
                              color:var(--ink); border-radius:var(--radius-sm); font-family:var(--font-mono); font-size:0.9em;"/>
                <div class="swe-mute" style="font-size:11px; margin-top:var(--space-xs);">
                    DLQ 및 SLA 알림 시 전역 webhook 대신 이 URL로 발송. 비워두면 전역(engine.dlq.webhook-url / engine.sla.webhook-url) 사용.
                </div>
            </div>
            <!-- #138 — SLA override -->
            <div style="display:grid; grid-template-columns: 1fr 1fr; gap: var(--space-md);">
                <div>
                    <label for="run-sla-seconds" style="display:block; font-weight:600; margin-bottom:var(--space-xs);">SLA (seconds)</label>
                    <input type="number" id="run-sla-seconds" min="1" step="1" placeholder="예: 3600"
                           style="width:100%; padding:var(--space-sm); background:var(--surface-2); border:1px solid var(--line);
                                  color:var(--ink); border-radius:var(--radius-sm); font-family:var(--font-mono); font-size:0.9em;"/>
                    <div class="swe-mute" style="font-size:11px; margin-top:var(--space-xs);">
                        비워두면 정의의 default SLA 사용. 0/빈값 = SLA override 없음.
                    </div>
                </div>
                <div>
                    <label for="run-sla-action" style="display:block; font-weight:600; margin-bottom:var(--space-xs);">SLA action</label>
                    <select id="run-sla-action"
                            style="width:100%; padding:var(--space-sm); background:var(--surface-2); border:1px solid var(--line);
                                   color:var(--ink); border-radius:var(--radius-sm); font-size:0.9em;">
                        <option value="">— inherit —</option>
                        <option value="ALERT_ONLY">ALERT_ONLY</option>
                        <option value="AUTO_TERMINATE">AUTO_TERMINATE</option>
                    </select>
                </div>
            </div>
        </div>
    </details>

    <div id="run-modal-error" style="display:none; color:var(--accent-pink); font-size:13px; margin-top:var(--space-md);"></div>
    <div style="display:flex; gap:var(--space-md); margin-top:var(--space-lg); justify-content:flex-end;">
        <button type="button" class="swe-btn-tertiary" onclick="closeRunModal()">Cancel</button>
        <button type="button" class="swe-btn-primary" id="run-modal-submit" onclick="submitRun()">▶ Run now</button>
    </div>
</div>

<script id="graph-data" type="application/json">{{{graphJson}}}</script>
<script src="/js/subway-map.js"></script>
<script>
(function () {
    const raw = document.getElementById('graph-data').textContent;
    const graph = JSON.parse(raw);
    const target = document.getElementById('subway-map');
    const panel = document.getElementById('station-detail');

    function showDetail(node) {
        document.getElementById('station-detail-name').textContent = node.name || node.id;
        document.getElementById('station-detail-activity').textContent = node.activity || '—';
        document.getElementById('station-detail-id').textContent = node.id;
        document.getElementById('station-detail-params').textContent = node.inputParams || '—';
        panel.style.display = 'block';
    }

    const map = Station8SubwayMap.render(target, graph, {
        interactive: true,
        onStationClick: (node) => {
            showDetail(node);
            highlightListItem(node.id);
        }
    });
    document.getElementById('station-detail-close').addEventListener('click', () => {
        panel.style.display = 'none';
    });

    // #135 — 좌측 stations list 렌더링 + 검색 + 클릭→focusStation
    const sortedNodes = Station8SubwayMap.topologicalOrder(graph);
    const listEl = document.getElementById('stations-list');
    const searchEl = document.getElementById('stations-search');

    function renderList(filter) {
        const q = (filter || '').trim().toLowerCase();
        const filtered = sortedNodes.filter(n => {
            if (!q) return true;
            const hay = (n.name || '').toLowerCase() + ' ' + (n.activity || '').toLowerCase();
            return hay.indexOf(q) !== -1;
        });
        if (filtered.length === 0) {
            listEl.innerHTML = '<div class="swe-station-list-empty">' +
                (q ? '"' + escapeHtml(q) + '" 일치 없음' : '역(Station)이 없습니다') + '</div>';
            return;
        }
        listEl.innerHTML = '';
        filtered.forEach(n => {
            const item = document.createElement('div');
            item.className = 'swe-station-list-item';
            item.dataset.nodeId = n.id;
            const activity = escapeHtml(n.activity || '—');
            const name = escapeHtml(n.name || n.id);
            // 추천 D7: activity(굵게) + name(메타). 같으면 name만.
            if (n.name && n.name !== n.activity) {
                item.innerHTML = '<div class="activity">' + activity + '</div>' +
                    '<div class="meta">' + name + '</div>';
            } else {
                item.innerHTML = '<div class="activity">' + activity + '</div>';
            }
            item.addEventListener('click', () => map.focusStation(n.id));
            listEl.appendChild(item);
        });
    }

    function highlightListItem(nodeId) {
        listEl.querySelectorAll('.swe-station-list-item').forEach(el => {
            el.classList.toggle('active', el.dataset.nodeId === nodeId);
        });
    }

    function escapeHtml(s) {
        return String(s).replace(/[&<>"']/g, c => ({
            '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;'
        })[c]);
    }

    renderList('');
    searchEl.addEventListener('input', () => renderList(searchEl.value));
})();

// #133 — Run now 모달 + POST /api/line/definitions/{id}/run + redirect
const DEFINITION_ID = '{{definitionId}}';

window.openRunModal = function () {
    document.getElementById('run-modal-backdrop').style.display = 'block';
    document.getElementById('run-modal').style.display = 'block';
    document.getElementById('run-modal-error').style.display = 'none';
    setTimeout(() => document.getElementById('run-input-data').focus(), 50);
};

window.closeRunModal = function () {
    document.getElementById('run-modal-backdrop').style.display = 'none';
    document.getElementById('run-modal').style.display = 'none';
};

window.submitRun = async function () {
    const errorEl = document.getElementById('run-modal-error');
    const submitBtn = document.getElementById('run-modal-submit');
    errorEl.style.display = 'none';
    submitBtn.disabled = true;
    submitBtn.textContent = 'Starting…';
    try {
        const inputData = document.getElementById('run-input-data').value.trim();

        // #134 — Advanced options
        const onFailure = document.getElementById('run-on-failure').value;
        const paramsRaw = document.getElementById('run-runtime-params').value.trim();
        const webhook = document.getElementById('run-webhook').value.trim();

        let runtimeParams = null;
        if (paramsRaw) {
            try {
                const parsed = JSON.parse(paramsRaw);
                if (parsed === null || typeof parsed !== 'object' || Array.isArray(parsed)) {
                    throw new Error('객체(JSON object)여야 합니다');
                }
                runtimeParams = parsed;
            } catch (parseErr) {
                throw new Error('Runtime params 파싱 실패 — ' + parseErr.message);
            }
        }

        // #138 — SLA override
        const slaSecondsRaw = document.getElementById('run-sla-seconds').value.trim();
        const slaAction = document.getElementById('run-sla-action').value;
        const slaSeconds = slaSecondsRaw ? parseInt(slaSecondsRaw, 10) : null;

        // options는 default와 다를 때만 포함 (서버측 default 동작 유지)
        const options = {};
        if (onFailure && onFailure !== 'CONTINUE') options.onFailure = onFailure;
        if (runtimeParams && Object.keys(runtimeParams).length > 0) options.runtimeParams = runtimeParams;
        if (webhook) options.notificationWebhookUrl = webhook;
        if (slaSeconds && slaSeconds > 0) options.slaSeconds = slaSeconds;
        if (slaAction) options.slaAction = slaAction;

        const body = {};
        if (inputData) body.input = inputData;
        if (Object.keys(options).length > 0) body.options = options;

        const res = await fetch('/api/line/definitions/' + DEFINITION_ID + '/run', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(body)
        });
        if (!res.ok) {
            const text = await res.text();
            throw new Error('HTTP ' + res.status + (text ? ' — ' + text : ''));
        }
        const data = await res.json();
        // 새 인스턴스 timeline으로 redirect — Azkaban 패턴 답습
        window.location.href = '/line/instance/' + data.instanceId;
    } catch (e) {
        errorEl.textContent = '실행 실패: ' + e.message;
        errorEl.style.display = 'block';
        submitBtn.disabled = false;
        submitBtn.textContent = '▶ Run now';
    }
};

// ESC 또는 backdrop 클릭으로 닫기
document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && document.getElementById('run-modal').style.display === 'block') {
        closeRunModal();
    }
});
document.getElementById('run-modal-backdrop').addEventListener('click', closeRunModal);
</script>
