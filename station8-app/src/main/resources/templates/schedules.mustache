<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <title>Schedules — Line Engine</title>
    <link rel="stylesheet" href="/css/design.css">
</head>
<body>
{{> _nav }}

<div class="swe-container" style="padding-top: var(--space-xxl); padding-bottom: var(--space-section);">

    <div class="swe-flex-between swe-mb-xl">
        <div>
            <h1 class="swe-display-lg" style="margin: 0;">Schedules</h1>
            <p class="swe-body-md swe-mute" style="margin: var(--space-sm) 0 0;">DAG 정기 실행 cron 스케줄 관리</p>
        </div>
        <button type="button" class="swe-btn-primary" onclick="openCreate()">+ New Schedule</button>
    </div>

    <!-- 통계 -->
    <div class="swe-grid swe-grid-3 swe-mb-xl">
        <div class="swe-stat-card">
            <div class="swe-stat-label" style="color: var(--accent-green);">Active</div>
            <div class="swe-stat-value">{{activeCount}}</div>
        </div>
        <div class="swe-stat-card">
            <div class="swe-stat-label" style="color: var(--accent-yellow);">Paused</div>
            <div class="swe-stat-value">{{pausedCount}}</div>
        </div>
        <div class="swe-stat-card">
            <div class="swe-stat-label">Total</div>
            <div class="swe-stat-value">{{totalCount}}</div>
        </div>
    </div>

    <!-- 테이블 -->
    <div class="swe-card" style="padding: 0;">
        <table class="swe-table">
            <thead>
            <tr>
                <th>ID</th>
                <th>Definition</th>
                <th>Cron</th>
                <th>Next run</th>
                <th>Last run</th>
                <th>Status</th>
                <th class="swe-text-right">Actions</th>
            </tr>
            </thead>
            <tbody>
            {{#schedules}}
            <tr>
                <td class="swe-id-cell" title="{{id}}">{{id}}</td>
                <td class="swe-id-cell" title="{{definitionId}}">{{definitionId}}</td>
                <td><span class="swe-keycap">{{cronExpr}}</span></td>
                <td class="swe-mute">{{#nextRunDt}}{{nextRunDt}}{{/nextRunDt}}{{^nextRunDt}}—{{/nextRunDt}}</td>
                <td class="swe-mute">{{#lastRunDt}}{{lastRunDt}}{{/lastRunDt}}{{^lastRunDt}}—{{/lastRunDt}}</td>
                <td>
                    {{#isPaused}}<span class="swe-badge swe-badge-warning">Paused</span>{{/isPaused}}
                    {{^isPaused}}<span class="swe-badge swe-badge-success">Active</span>{{/isPaused}}
                </td>
                <td class="swe-text-right">
                    <button class="swe-btn-tertiary swe-btn-sm" onclick="runNow('{{id}}')">Run now</button>
                    {{#isPaused}}
                    <button class="swe-btn-tertiary swe-btn-sm" onclick="resume('{{id}}')">Resume</button>
                    {{/isPaused}}
                    {{^isPaused}}
                    <button class="swe-btn-tertiary swe-btn-sm" onclick="pause('{{id}}')">Pause</button>
                    {{/isPaused}}
                    <button class="swe-btn-tertiary swe-btn-sm swe-btn-danger" onclick="del('{{id}}')">Delete</button>
                </td>
            </tr>
            {{/schedules}}
            {{^schedules}}
            <tr>
                <td colspan="7" style="text-align: center; padding: var(--space-section) 0; color: var(--mute);">
                    No schedules. Click <strong style="color: var(--ink);">+ New Schedule</strong> to add one.
                </td>
            </tr>
            {{/schedules}}
            </tbody>
        </table>
    </div>

</div>

<!-- New schedule modal -->
<div class="swe-modal-backdrop" id="createModal" onclick="if(event.target===this)closeCreate()">
    <div class="swe-modal">
        <h2 class="swe-heading-xl" style="margin: 0 0 var(--space-lg);">New Schedule</h2>
        <div class="swe-stack">
            <div>
                <label for="definitionId">Definition ID</label>
                <input type="text" id="definitionId" class="swe-input" placeholder="UUID of an existing DAG definition">
            </div>
            <div>
                <label for="cronExpr">Cron expression (Spring 6-field: sec min hour day mon dow)</label>
                <input type="text" id="cronExpr" class="swe-input" placeholder="0 */5 * * * *" oninput="previewCron()">
                <div id="cronPreview" class="swe-caption" style="margin-top: var(--space-sm);"></div>
            </div>
            <div>
                <label for="inputData">Input data JSON (optional)</label>
                <textarea id="inputData" class="swe-input" rows="3" style="height: auto; padding: var(--space-md);" placeholder='{"key":"value"}'></textarea>
            </div>
        </div>
        <div class="swe-flex-between swe-mt-xl">
            <button type="button" class="swe-btn-secondary" onclick="closeCreate()">Cancel</button>
            <button type="button" class="swe-btn-primary" onclick="createSchedule()">Create</button>
        </div>
    </div>
</div>

<script>
function openCreate() { document.getElementById('createModal').classList.add('open'); }
function closeCreate() { document.getElementById('createModal').classList.remove('open'); }

async function previewCron() {
    const expr = document.getElementById('cronExpr').value;
    const preview = document.getElementById('cronPreview');
    if (!expr) { preview.textContent = ''; return; }
    try {
        const res = await fetch('/api/line/schedules/preview-cron?cronExpr=' + encodeURIComponent(expr));
        const j = await res.json();
        if (j.valid) {
            preview.style.color = 'var(--accent-green)';
            preview.textContent = 'Next: ' + j.next1 + ' · ' + j.next2 + ' · ' + j.next3;
        } else {
            preview.style.color = 'var(--accent-red)';
            preview.textContent = j.message || 'Invalid cron expression';
        }
    } catch (e) { preview.textContent = e.message; }
}

async function createSchedule() {
    const body = {
        definitionId: document.getElementById('definitionId').value,
        cronExpr: document.getElementById('cronExpr').value,
        inputData: document.getElementById('inputData').value || null
    };
    const res = await fetch('/api/line/schedules', {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify(body)
    });
    if (res.ok) location.reload();
    else alert('Create failed: ' + (await res.text()));
}

async function runNow(id) {
    if (!confirm('Run this schedule now (independent of cron)?')) return;
    const res = await fetch('/api/line/schedules/' + id + '/run-now', {method: 'POST'});
    if (res.ok) {
        const j = await res.json();
        alert('Triggered. instanceId=' + j.instanceId);
        location.reload();
    } else alert('Failed: ' + (await res.text()));
}
async function pause(id) {
    const res = await fetch('/api/line/schedules/' + id + '/pause', {method: 'PUT'});
    if (res.ok) location.reload();
}
async function resume(id) {
    const res = await fetch('/api/line/schedules/' + id + '/resume', {method: 'PUT'});
    if (res.ok) location.reload();
}
async function del(id) {
    if (!confirm('Delete this schedule?')) return;
    const res = await fetch('/api/line/schedules/' + id, {method: 'DELETE'});
    if (res.ok) location.reload();
}
</script>
</body>
</html>
