<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <title>DLQ — Line Engine</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    <link rel="stylesheet" href="/css/design.css">
</head>
<body>
{{> _nav }}

<div class="swe-container" style="padding-top: var(--space-xxl); padding-bottom: var(--space-section);">

    <div class="swe-flex-between swe-mb-xl">
        <div>
            <h1 class="swe-display-lg" style="margin: 0;">Dead Letter Queue</h1>
            <p class="swe-body-md swe-mute" style="margin: var(--space-sm) 0 0;">최대 재시도 초과한 액티비티 — Requeue 또는 Discard</p>
        </div>
    </div>

    <!-- 통계 -->
    <div class="swe-grid swe-grid-4 swe-mb-xl">
        <div class="swe-stat-card">
            <div class="swe-stat-label">Total</div>
            <div class="swe-stat-value">{{totalDlqCount}}</div>
        </div>
        <div class="swe-stat-card">
            <div class="swe-stat-label" style="color: var(--accent-red);">NEW</div>
            <div class="swe-stat-value">{{newCount}}</div>
        </div>
        <div class="swe-stat-card">
            <div class="swe-stat-label" style="color: var(--accent-blue);">REQUEUED</div>
            <div class="swe-stat-value">{{requeuedCount}}</div>
        </div>
        <div class="swe-stat-card">
            <div class="swe-stat-label">DISCARDED</div>
            <div class="swe-stat-value">{{discardedCount}}</div>
        </div>
    </div>

    <!-- 검색/필터 (#137) -->
    <div class="swe-card-elevated swe-mb-xl">
        <form method="get" action="/line/dlq">
            <div class="swe-grid swe-grid-3">
                <div>
                    <label for="dlq-workflow">Line Name</label>
                    <input type="text" id="dlq-workflow" name="workflowName" class="swe-input"
                           value="{{#workflowName}}{{workflowName}}{{/workflowName}}" placeholder="Name substring">
                </div>
                <div>
                    <label for="dlq-activity">Activity</label>
                    <input type="text" id="dlq-activity" name="activityName" class="swe-input"
                           value="{{#activityName}}{{activityName}}{{/activityName}}" placeholder="Activity 이름 substring">
                </div>
                <div style="display: flex; align-items: end; gap: var(--space-md); justify-content: flex-end;">
                    <a href="/line/dlq" class="swe-btn-secondary">Reset</a>
                    <button type="submit" class="swe-btn-primary">Apply</button>
                </div>
            </div>
            <details {{#advancedOpen}}open{{/advancedOpen}} style="margin-top: var(--space-md);">
                <summary style="cursor: pointer; font-weight: 600; user-select: none;">More filters</summary>
                <div style="margin-top: var(--space-md); display: flex; flex-direction: column; gap: var(--space-md);">
                    <div>
                        <label for="dlq-error-message">Error message (부분일치)</label>
                        <input type="text" id="dlq-error-message" name="errorMessage" class="swe-input"
                               value="{{#errorMessage}}{{errorMessage}}{{/errorMessage}}" placeholder="예: Timeout / NullPointerException">
                    </div>
                    <div>
                        <label style="display:block; margin-bottom: var(--space-xs); font-weight: 600;">DLQ Status (다중)</label>
                        <div style="display: flex; gap: var(--space-md); flex-wrap: wrap;">
                            <label style="display:flex; align-items:center; gap: var(--space-xs); cursor:pointer;">
                                <input type="checkbox" name="dlqStatusSt" value="NEW" {{#selectedNew}}checked{{/selectedNew}}>
                                <span class="swe-badge swe-badge-danger">NEW</span>
                            </label>
                            <label style="display:flex; align-items:center; gap: var(--space-xs); cursor:pointer;">
                                <input type="checkbox" name="dlqStatusSt" value="REQUEUED" {{#selectedRequeued}}checked{{/selectedRequeued}}>
                                <span class="swe-badge swe-badge-info">REQUEUED</span>
                            </label>
                            <label style="display:flex; align-items:center; gap: var(--space-xs); cursor:pointer;">
                                <input type="checkbox" name="dlqStatusSt" value="DISCARDED" {{#selectedDiscarded}}checked{{/selectedDiscarded}}>
                                <span class="swe-badge swe-badge-mute">DISCARDED</span>
                            </label>
                        </div>
                    </div>
                    <div class="swe-grid swe-grid-2" style="gap: var(--space-md);">
                        <div>
                            <label for="dlq-failed-from">Failed at from</label>
                            <input type="date" id="dlq-failed-from" name="failedAtFrom" class="swe-input"
                                   value="{{failedAtFrom}}">
                        </div>
                        <div>
                            <label for="dlq-failed-to">Failed at to</label>
                            <input type="date" id="dlq-failed-to" name="failedAtTo" class="swe-input"
                                   value="{{failedAtTo}}">
                        </div>
                    </div>
                </div>
            </details>
            <input type="hidden" name="sortBy" value="{{sortBy}}">
            <input type="hidden" name="sortDir" value="{{sortDir}}">
        </form>
    </div>

    <div class="swe-card" style="padding: 0;">
        <table class="swe-table">
            <thead>
            <tr>
                <th>ID</th>
                <th>Line</th>
                <th>
                    <a href="{{{activitySortHref}}}" class="swe-mute" style="text-decoration:none;">
                        Activity {{#sortActivity}}{{#sortAsc}}▲{{/sortAsc}}{{^sortAsc}}▼{{/sortAsc}}{{/sortActivity}}
                    </a>
                </th>
                <th>Status</th>
                <th>Retry</th>
                <th>
                    <a href="{{{failedAtSortHref}}}" class="swe-mute" style="text-decoration:none;">
                        Failed at {{#sortFailedAt}}{{#sortAsc}}▲{{/sortAsc}}{{^sortAsc}}▼{{/sortAsc}}{{/sortFailedAt}}
                    </a>
                </th>
                <th class="swe-text-right">Actions</th>
            </tr>
            </thead>
            <tbody>
            {{#dlqEntries}}
            <tr>
                <td class="swe-id-cell" title="{{id}}">{{id}}</td>
                <td>{{workflowName}}</td>
                <td>{{activityName}}</td>
                <td>
                    <span class="swe-badge swe-badge-{{badgeClass}}">{{dlqStatusSt}}</span>
                </td>
                <td class="swe-mute">{{retryCnt}} / {{maxRetryCnt}}</td>
                <td class="swe-mute">{{failedAtDt}}</td>
                <td class="swe-text-right">
                    <a href="/line/dlq/{{id}}" class="swe-btn-tertiary swe-btn-sm">Detail</a>
                    {{#isNew}}
                    <form action="/line/dlq/{{id}}/requeue" method="post" style="display:inline;">
                        {{> _csrf}}
                        <button type="submit" class="swe-btn-tertiary swe-btn-sm">Requeue</button>
                    </form>
                    <form action="/line/dlq/{{id}}/discard" method="post" style="display:inline;">
                        {{> _csrf}}
                        <button type="submit" class="swe-btn-tertiary swe-btn-sm swe-btn-danger">Discard</button>
                    </form>
                    {{/isNew}}
                </td>
            </tr>
            {{/dlqEntries}}
            {{^dlqEntries}}
            <tr>
                <td colspan="7" style="text-align: center; padding: var(--space-section) 0; color: var(--mute);">
                    No DLQ entries.
                </td>
            </tr>
            {{/dlqEntries}}
            </tbody>
        </table>
        {{> _pagination }}
    </div>

</div>
</body>
</html>
