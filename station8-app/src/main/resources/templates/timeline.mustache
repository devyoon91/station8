<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <title>Instance Timeline — Line Engine</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    <link rel="stylesheet" href="/css/design.css">
    <style>
        .swe-timeline { position: relative; padding-left: 24px; margin: 0; list-style: none; }
        .swe-timeline:before { content: ""; position: absolute; top: 8px; bottom: 8px; left: 7px; width: 1px; background: var(--hairline); }
        .swe-timeline-item { position: relative; padding: 0 0 var(--space-lg) 0; }
        .swe-timeline-dot {
            position: absolute; left: -22px; top: 14px;
            width: 10px; height: 10px; border-radius: 50%;
            border: 2px solid var(--canvas);
            background: var(--mute);
        }
        .swe-timeline-dot.completed { background: var(--accent-green); }
        .swe-timeline-dot.running   { background: var(--accent-yellow); }
        .swe-timeline-dot.failed    { background: var(--accent-red); }
        .swe-timeline-dot.pending   { background: var(--mute); }

        /* M3: 역 클릭 시 timeline 카드 일시 강조 */
        .swe-timeline-item.flash > .swe-card {
            animation: swe-card-flash 1.6s ease-out;
        }
        @keyframes swe-card-flash {
            0%   { box-shadow: 0 0 0 2px var(--line-brand); }
            100% { box-shadow: 0 0 0 0 transparent; }
        }

        /* #132 — Auto-refresh 인디케이터 */
        .live-indicator {
            display: inline-flex;
            align-items: center;
            gap: var(--space-sm);
            font-size: 12px;
            color: var(--mute);
        }
        .live-indicator .pulse {
            width: 8px; height: 8px; border-radius: 50%;
            background: var(--accent-green);
            animation: live-pulse 1.4s ease-in-out infinite;
        }
        @keyframes live-pulse {
            0%, 100% { opacity: 0.35; }
            50%      { opacity: 1; }
        }
        .live-indicator.off .pulse { animation: none; background: var(--mute); opacity: 0.5; }
    </style>
</head>
<body>
{{> _nav }}

<div class="swe-container" style="padding-top: var(--space-xxl); padding-bottom: var(--space-section);">

    <div class="swe-flex-between swe-mb-xl">
        <div>
            <a href="/line/dashboard" class="swe-caption swe-mute" style="text-decoration: none;">← Dashboard</a>
            <h1 class="swe-display-lg" style="margin: var(--space-xs) 0 0;">Instance Timeline</h1>
            {{#instance.isRunning}}
            <div class="live-indicator" id="live-indicator">
                <span class="pulse"></span>
                <span>Auto-refresh 3s</span>
                <span style="margin-left: var(--space-xs);" id="updated-at"></span>
                <button type="button" class="swe-btn-tertiary swe-btn-sm" id="auto-refresh-toggle"
                        style="margin-left: var(--space-md);" onclick="toggleAutoRefresh()">Pause</button>
            </div>
            {{/instance.isRunning}}
        </div>
        <div class="swe-row">
            {{#instance.isFailed}}
            <form action="/line/instance/{{instance.id}}/resume" method="post" style="margin: 0;">
                {{> _csrf}}
                <button type="submit" class="swe-btn-primary" title="모든 FAILED 활동을 PENDING으로 reset + 인스턴스 RUNNING 복원">Resume from failure</button>
            </form>
            {{/instance.isFailed}}
            {{#instance.isPaused}}
            <!-- #139 — PAUSED: Unpause(재개) + Terminate -->
            <form action="/line/instance/{{instance.id}}/unpause" method="post" style="margin: 0;">
                {{> _csrf}}
                <button type="submit" class="swe-btn-primary" title="일시정지 해제 — RUNNING 복원 + fan-out 재평가">▶ Resume (unpause)</button>
            </form>
            <form action="/line/instance/{{instance.id}}/terminate" method="post" style="margin: 0;"
                  onsubmit="return confirm('인스턴스를 강제 종료합니까? 진행 중 액티비티는 워커가 자연 완료한 뒤 후행이 차단됩니다.');">
                {{> _csrf}}
                <button type="submit" class="swe-btn-tertiary swe-btn-danger">Terminate</button>
            </form>
            {{/instance.isPaused}}
            {{#instance.isRunning}}
            <!-- #139 — RUNNING: Pause + Terminate -->
            <form action="/line/instance/{{instance.id}}/pause" method="post" style="margin: 0;"
                  onsubmit="return confirm('인스턴스를 일시 정지합니까? PENDING 활동은 워커 폴링이 차단되며, 진행 중 RUNNING 활동은 자연 완료됩니다.');">
                {{> _csrf}}
                <button type="submit" class="swe-btn-tertiary" title="일시 정지 — PAUSED 상태로 전환">⏸ Pause</button>
            </form>
            <form action="/line/instance/{{instance.id}}/terminate" method="post" style="margin: 0;"
                  onsubmit="return confirm('인스턴스를 강제 종료합니까? 진행 중 액티비티는 워커가 자연 완료한 뒤 후행이 차단됩니다.');">
                {{> _csrf}}
                <button type="submit" class="swe-btn-tertiary swe-btn-danger">Terminate</button>
            </form>
            {{/instance.isRunning}}
        </div>
    </div>

    {{#terminateMsg}}
    <div class="swe-card swe-mb-xl" style="padding: var(--space-md) var(--space-lg); border-left: 4px solid {{#terminateOk}}var(--accent-green){{/terminateOk}}{{^terminateOk}}var(--accent-pink){{/terminateOk}};">
        <code style="color: var(--ink); font-size: 0.95em;">{{terminateMsg}}</code>
    </div>
    {{/terminateMsg}}

    <!-- Instance meta -->
    <div class="swe-card swe-mb-xl">
        <div class="swe-grid swe-grid-3">
            <div>
                <div class="swe-caption swe-mute">Instance ID</div>
                <div style="font-family: monospace; font-size: 13px;">{{instance.id}}</div>
            </div>
            <div>
                <div class="swe-caption swe-mute">Line</div>
                <div class="swe-body-md">{{instance.workflowName}}</div>
            </div>
            <div>
                <div class="swe-caption swe-mute">Status</div>
                <div><span class="swe-badge swe-badge-{{instance.badgeClass}}" id="instance-status-badge">{{instance.statusSt}}</span></div>
            </div>
        </div>
        {{#instance.inputData}}
        <div style="margin-top: var(--space-lg);">
            <div class="swe-caption swe-mute">Input data</div>
            <pre style="margin: var(--space-xs) 0 0; padding: var(--space-md); background: var(--surface-card); border-radius: var(--radius-md); color: var(--body); font-size: 12px; overflow-x: auto;">{{instance.inputData}}</pre>
        </div>
        {{/instance.inputData}}
    </div>

    {{#hasSubway}}
    <h2 class="swe-heading-md swe-mb-xl" style="margin-top: 0;">Line view</h2>
    <div class="swe-subway-frame swe-mb-xl">
        <div id="subway-map"></div>
    </div>
    {{/hasSubway}}

    <h2 class="swe-heading-md swe-mb-xl" style="margin-top: 0;">Execution history</h2>

    <ul class="swe-timeline">
        {{#activities}}
        <li class="swe-timeline-item" data-node-id="{{nodeId}}" data-activity-id="{{id}}" id="exec-{{nodeId}}">
            <span class="swe-timeline-dot {{dotClass}}" data-role="dot"></span>
            <div class="swe-card swe-card-tight">
                <div class="swe-flex-between">
                    <div>
                        <div class="swe-heading-sm" style="margin: 0 0 var(--space-xs);">{{activityName}}</div>
                        <div class="swe-caption swe-mute" data-role="time">Started: {{startDt}}{{#endDt}} · Ended: {{endDt}}{{/endDt}}</div>
                    </div>
                    <span class="swe-badge swe-badge-{{badgeClass}}" data-role="badge">{{statusSt}}</span>
                </div>
                {{#inputData}}
                <div style="margin-top: var(--space-md);">
                    <div class="swe-caption swe-mute">Input</div>
                    <pre style="margin: var(--space-xs) 0 0; padding: var(--space-sm); background: var(--surface-card); border-radius: var(--radius-sm); font-size: 12px;">{{inputData}}</pre>
                </div>
                {{/inputData}}
                {{#outputData}}
                <div style="margin-top: var(--space-md);">
                    <div class="swe-caption swe-mute">Output</div>
                    <pre style="margin: var(--space-xs) 0 0; padding: var(--space-sm); background: var(--surface-card); border-radius: var(--radius-sm); font-size: 12px;">{{outputData}}</pre>
                </div>
                {{/outputData}}
                {{#errorMessage}}
                <div style="margin-top: var(--space-md); padding: var(--space-md); background: var(--accent-red-soft); border-radius: var(--radius-md); color: var(--accent-red); font-size: 13px;">
                    <strong>Error:</strong> {{errorMessage}}
                </div>
                {{/errorMessage}}
                {{#hasRetry}}
                <div class="swe-caption swe-mute" style="margin-top: var(--space-sm);">Retry attempt: {{retryCnt}}</div>
                {{/hasRetry}}
                {{#isActivityFailed}}{{#instance.isRunning}}
                <!-- #139 — 활동 단위 retry. 인스턴스가 RUNNING일 때만 노출. -->
                <div style="margin-top: var(--space-md); display: flex; justify-content: flex-end;">
                    <form action="/line/instance/{{instance.id}}/activity/{{id}}/retry" method="post"
                          onsubmit="return confirm('이 활동만 PENDING으로 reset해 다시 시도합니까?');"
                          style="margin: 0;">
                        {{> _csrf}}
                        <button type="submit" class="swe-btn-tertiary swe-btn-sm" title="이 활동만 PENDING으로 reset (단건 retry)">↻ Retry this activity</button>
                    </form>
                </div>
                {{/instance.isRunning}}{{/isActivityFailed}}
            </div>
        </li>
        {{/activities}}
        {{^activities}}
        <li>
            <div class="swe-card" style="text-align: center; color: var(--mute);">No activity records.</div>
        </li>
        {{/activities}}
    </ul>

</div>

{{#hasSubway}}
<script id="subway-data" type="application/json">{{{subwayJson}}}</script>
<script src="/js/subway-map.js"></script>
<script>
// 노선도 — 초기 렌더 + #132 AJAX 갱신 시 statusByNode만 업데이트 후 재렌더
window.__subwayGraph = JSON.parse(document.getElementById('subway-data').textContent);
function renderSubway() {
    Station8SubwayMap.render(document.getElementById('subway-map'), window.__subwayGraph, {
        interactive: true,
        onStationClick: (node) => {
            const card = document.getElementById('exec-' + node.id);
            if (!card) return;
            card.scrollIntoView({ behavior: 'smooth', block: 'center' });
            card.classList.add('flash');
            setTimeout(() => card.classList.remove('flash'), 1600);
        }
    });
}
renderSubway();
</script>
{{/hasSubway}}

<!-- #132 — 인스턴스가 RUNNING이면 3초 폴링으로 instance/activities/노선도 부분 갱신 -->
<script>
(function () {
    const INSTANCE_ID = '{{instance.id}}';
    const POLL_INTERVAL_MS = 3000;
    const isRunningInitially = {{#instance.isRunning}}true{{/instance.isRunning}}{{^instance.isRunning}}false{{/instance.isRunning}};

    let pollTimer = null;
    let paused = false;

    window.toggleAutoRefresh = function () {
        const btn = document.getElementById('auto-refresh-toggle');
        const indicator = document.getElementById('live-indicator');
        if (paused) {
            paused = false;
            if (btn) btn.textContent = 'Pause';
            if (indicator) indicator.classList.remove('off');
            startPoll();
        } else {
            paused = true;
            if (btn) btn.textContent = 'Resume';
            if (indicator) indicator.classList.add('off');
            stopPoll();
        }
    };

    function startPoll() {
        stopPoll();
        pollTimer = setInterval(refreshState, POLL_INTERVAL_MS);
        refreshState();  // 즉시 한 번
    }

    function stopPoll() {
        if (pollTimer) { clearInterval(pollTimer); pollTimer = null; }
    }

    function hideIndicator() {
        const indicator = document.getElementById('live-indicator');
        if (indicator) indicator.style.display = 'none';
    }

    async function refreshState() {
        try {
            const res = await fetch('/api/line/instances/' + INSTANCE_ID + '/state', {
                headers: { 'Accept': 'application/json' }
            });
            if (!res.ok) {
                if (res.status === 404) { stopPoll(); hideIndicator(); }
                return;
            }
            const data = await res.json();
            applyState(data);
            if (data.instance && data.instance.terminal === true) {
                stopPoll();
                hideIndicator();
            }
        } catch (e) {
            console.warn('state poll failed', e);
        }
    }

    function applyState(data) {
        // 1) 인스턴스 status badge
        const stBadge = document.getElementById('instance-status-badge');
        if (stBadge && data.instance) {
            stBadge.textContent = data.instance.statusSt;
            stBadge.className = 'swe-badge swe-badge-' + data.instance.badgeClass;
        }

        // 2) 활동 카드 — id 매칭 후 status/badge/dot/시간만 갱신
        (data.activities || []).forEach(a => {
            const li = document.querySelector('[data-activity-id="' + a.id + '"]');
            if (!li) return;  // 새 카드 추가는 비범위 — 사용자가 페이지 reload하면 보임
            const dot = li.querySelector('[data-role="dot"]');
            if (dot) dot.className = 'swe-timeline-dot ' + a.dotClass;
            const badge = li.querySelector('[data-role="badge"]');
            if (badge) {
                badge.textContent = a.statusSt;
                badge.className = 'swe-badge swe-badge-' + a.badgeClass;
            }
            const time = li.querySelector('[data-role="time"]');
            if (time) {
                let txt = a.startDt ? ('Started: ' + formatDt(a.startDt)) : 'Pending';
                if (a.endDt) txt += ' · Ended: ' + formatDt(a.endDt);
                time.textContent = txt;
            }
        });

        // 3) 노선도 — statusByNode 갱신 후 재렌더
        if (data.statusByNode && window.__subwayGraph) {
            window.__subwayGraph.statusByNode = data.statusByNode;
            if (typeof renderSubway === 'function') renderSubway();
        }

        // 4) "Updated HH:MM:SS"
        const updated = document.getElementById('updated-at');
        if (updated) {
            const now = new Date();
            updated.textContent = '· Updated ' + now.toLocaleTimeString();
        }
    }

    function formatDt(iso) {
        // 백엔드가 LocalDateTime 직렬화 → '2026-05-09T12:34:56' 또는 비슷
        if (!iso) return '';
        return iso.toString().replace('T', ' ').substring(0, 19);
    }

    if (isRunningInitially) {
        startPoll();
    }
})();
</script>
</body>
</html>
