<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <title>{{title}} — Station8</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    <link rel="stylesheet" href="/css/design.css">
</head>
<body>
{{> _nav }}

<div class="swe-container" style="padding-top: var(--space-xxl); padding-bottom: var(--space-section); max-width: 760px;">

    <div class="swe-mb-xl">
        <a href="/admin/credentials" class="swe-mute" style="text-decoration:none; font-size: 0.9em;">← Credentials</a>
        <h1 class="swe-display-lg" style="margin: var(--space-sm) 0 0;">{{title}}</h1>
    </div>

    <form action="{{submitUrl}}" method="post" class="swe-card" style="padding: var(--space-xl);">
        {{> _csrf}}

        <div class="swe-mb-lg">
            <label for="cred-name" class="swe-label">Name *</label>
            <input id="cred-name" name="name" type="text" required value="{{form.name}}"
                   class="swe-input" placeholder="예: openai-prod, ldap-bind, slack-hook"
                   pattern="^[a-zA-Z0-9._\-]+$"
                   title="영문/숫자/._- 만 (Builder picker에서 식별자로 사용)">
            <p class="swe-mute" style="font-size: 0.85em; margin: var(--space-xs) 0 0;">
                식별자로 노드 inputParams에서 <code>{{=<% %>=}}{{ $credentials.&lt;name&gt;.value }}<%={{ }}=%></code>로 참조.
            </p>
        </div>

        <div class="swe-mb-lg">
            <label for="cred-type" class="swe-label">Type *</label>
            <select id="cred-type" name="type" required class="swe-input" onchange="updateSchemaFields()">
                <option value="">— select —</option>
                {{#supportedTypes}}
                <option value="{{.}}">{{.}}</option>
                {{/supportedTypes}}
            </select>
            <p class="swe-mute" id="cred-type-hint" style="font-size: 0.85em; margin: var(--space-xs) 0 0;"></p>
        </div>

        <div class="swe-mb-lg">
            <label for="cred-value" class="swe-label">Value{{^isEdit}} *{{/isEdit}}</label>
            <input id="cred-value" name="value" type="password" autocomplete="new-password"
                   class="swe-input"
                   {{^isEdit}}required{{/isEdit}}
                   placeholder="{{#isEdit}}변경할 때만 입력 — 비우면 기존 value 유지{{/isEdit}}{{^isEdit}}credential 값 (서버에서 AES-GCM 암호화){{/isEdit}}">
            <p class="swe-mute" style="font-size: 0.85em; margin: var(--space-xs) 0 0;">
                Token / password / API key 본문. 저장 후엔 절대 다시 표시되지 않습니다.
                {{#isEdit}}수정 시 비워두면 기존 ciphertext 그대로.{{/isEdit}}
            </p>
        </div>

        <!-- Schema fields — type에 따라 JS가 show/hide -->
        <div id="schema-username" class="swe-mb-lg schema-field" style="display: none;">
            <label for="cred-schema-username" class="swe-label">schema.username</label>
            <input id="cred-schema-username" name="schemaUsername" type="text" value="{{form.schemaUsername}}"
                   class="swe-input" placeholder="HTTP Basic의 username (value=password)">
        </div>

        <div id="schema-header" class="swe-mb-lg schema-field" style="display: none;">
            <label for="cred-schema-header" class="swe-label">schema.header</label>
            <input id="cred-schema-header" name="schemaHeader" type="text" value="{{form.schemaHeader}}"
                   class="swe-input" placeholder="예: X-API-Key">
        </div>

        <div id="schema-baseurl" class="swe-mb-lg schema-field" style="display: none;">
            <label for="cred-schema-baseurl" class="swe-label">schema.baseUrl</label>
            <input id="cred-schema-baseurl" name="schemaBaseUrl" type="text" value="{{form.schemaBaseUrl}}"
                   class="swe-input"
                   placeholder="예: https://api.openai.com/v1, http://ollama.internal:11434/v1, https://api.anthropic.com">
        </div>

        <div class="swe-flex-end" style="gap: var(--space-sm);">
            <a href="/admin/credentials" class="swe-btn-secondary">Cancel</a>
            <button type="submit" class="swe-btn-primary">{{submitLabel}}</button>
        </div>
    </form>
</div>

<script>
    // type 변경 시 해당 schema 필드만 노출. 페이지 로드 시에도 1회 실행해 prefill 상태에 맞춤.
    const SCHEMA_BY_TYPE = {
        'http_basic': ['username'],
        'http_bearer': [],
        'api_key': ['header'],
        'generic': [],
        'sftp_password': [],
        'sftp_key': [],
        's3_access_key': [],
        'webhook_hmac': [],
        'openai_compatible': ['baseUrl'],
        'anthropic': ['baseUrl']
    };
    const TYPE_HINTS = {
        'http_basic': 'value=password, schema.username 필수',
        'http_bearer': 'value=token (Authorization: Bearer <value>로 주입)',
        'api_key': 'value=key, schema.header 필수 (예: X-API-Key)',
        'generic': 'value=임의 문자열 — 자동 헤더 주입 0, 사용자가 표현식으로',
        'sftp_password': 'value=password (M19 SFTP backend)',
        'sftp_key': 'value=private key (M19 SFTP backend)',
        's3_access_key': 'value=secret access key (M19 S3 backend)',
        'webhook_hmac': 'value=HMAC secret (M20 webhook trigger 검증)',
        'openai_compatible': 'value=apiKey (로컬 Ollama는 빈 값 OK), schema.baseUrl 필수',
        'anthropic': 'value=apiKey, schema.baseUrl 선택(기본 api.anthropic.com)'
    };
    function updateSchemaFields() {
        const type = document.getElementById('cred-type').value;
        const keys = SCHEMA_BY_TYPE[type] || [];
        document.getElementById('schema-username').style.display = keys.includes('username') ? '' : 'none';
        document.getElementById('schema-header').style.display = keys.includes('header') ? '' : 'none';
        document.getElementById('schema-baseurl').style.display = keys.includes('baseUrl') ? '' : 'none';
        document.getElementById('cred-type-hint').textContent = TYPE_HINTS[type] || '';
    }
    // prefill type (edit) — option value를 JS로 강제 선택 후 schema 필드 표시 갱신
    (function(){
        const presetType = '{{form.type}}';
        if (presetType) {
            const sel = document.getElementById('cred-type');
            for (const opt of sel.options) {
                if (opt.value === presetType) { opt.selected = true; break; }
            }
        }
        updateSchemaFields();
    })();
</script>
</body>
</html>
