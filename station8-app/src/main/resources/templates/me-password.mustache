<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <title>Change password — Station8</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    <link rel="stylesheet" href="/css/design.css">
</head>
<body>
{{> _nav }}

<div class="swe-container" style="padding-top: var(--space-xxl); padding-bottom: var(--space-section); max-width: 560px;">
    <h1 class="swe-display-lg" style="margin: 0 0 var(--space-md);">Change password</h1>
    <p class="swe-mute" style="margin: 0 0 var(--space-xl);">현재 사용자: <strong>{{username}}</strong></p>

    {{#pwMsg}}
    <div class="swe-card swe-mb-xl" style="padding: var(--space-md) var(--space-lg); border-left: 4px solid {{#pwOk}}var(--accent-green){{/pwOk}}{{^pwOk}}var(--accent-pink){{/pwOk}};">
        <code style="color: var(--ink); font-size: 0.95em;">{{pwMsg}}</code>
    </div>
    {{/pwMsg}}

    <form action="/me/password" method="post" class="swe-card" style="padding: var(--space-lg);">
        <input type="hidden" name="{{_csrf.parameterName}}" value="{{_csrf.token}}">
        <div style="margin-bottom: var(--space-md);">
            <label style="display:block;font-weight:600;margin-bottom:var(--space-xs);">현재 비밀번호</label>
            <input type="password" name="currentPassword" required
                   style="width:100%;padding:var(--space-sm);background:var(--surface-elevated);border:1px solid var(--hairline);color:var(--ink);border-radius:var(--radius-sm);box-sizing:border-box;">
        </div>
        <div style="margin-bottom: var(--space-md);">
            <label style="display:block;font-weight:600;margin-bottom:var(--space-xs);">새 비밀번호</label>
            <input type="password" name="newPassword" required minlength="8"
                   style="width:100%;padding:var(--space-sm);background:var(--surface-elevated);border:1px solid var(--hairline);color:var(--ink);border-radius:var(--radius-sm);box-sizing:border-box;">
            <div class="swe-mute" style="font-size:11px;margin-top:var(--space-xs);">8자+ · 숫자 1+ · 특수문자 1+</div>
        </div>
        <div style="margin-bottom: var(--space-md);">
            <label style="display:block;font-weight:600;margin-bottom:var(--space-xs);">새 비밀번호 확인</label>
            <input type="password" name="confirmPassword" required minlength="8"
                   style="width:100%;padding:var(--space-sm);background:var(--surface-elevated);border:1px solid var(--hairline);color:var(--ink);border-radius:var(--radius-sm);box-sizing:border-box;">
        </div>
        <button type="submit" class="swe-btn-primary">변경</button>
    </form>
</div>
</body>
</html>
