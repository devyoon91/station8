<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <title>Lines — Station8</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    <link rel="stylesheet" href="/css/design.css">
</head>
<body>
{{> _nav }}

<div class="swe-container" style="padding-top: var(--space-xxl); padding-bottom: var(--space-section);">

    <div class="swe-flex-between swe-mb-xl">
        <div>
            <h1 class="swe-display-lg" style="margin: 0;">Lines</h1>
            <p class="swe-body-md swe-mute" style="margin: var(--space-sm) 0 0;">활성 라인 정의 ({{totalCount}}건) — 노선도로 보거나 빌더에서 새 라인을 만든다</p>
        </div>
        <div class="swe-row">
            <!-- #193 — JSON export 파일을 업로드해 정의 import. -->
            <button type="button" class="swe-btn-tertiary" onclick="openImportModal()">⬆ Import</button>
            <a href="/line/builder" class="swe-btn-primary">+ New Line</a>
        </div>
    </div>

    <!-- #142 — 검색 / 태그 필터 -->
    <div class="swe-card-elevated swe-mb-xl">
        <form method="get" action="/line/definitions" class="swe-grid swe-grid-3" style="gap: var(--space-md); align-items: end;">
            <div>
                <label for="defs-name">Line name</label>
                <input type="text" id="defs-name" name="name" class="swe-input"
                       value="{{#filterName}}{{filterName}}{{/filterName}}" placeholder="이름 부분일치">
            </div>
            <div>
                <label for="defs-tag">Tag</label>
                <input type="text" id="defs-tag" name="tag" class="swe-input"
                       value="{{#filterTag}}{{filterTag}}{{/filterTag}}" placeholder="정확 일치 (e.g. etl)">
            </div>
            <div style="display:flex; gap: var(--space-md); justify-content: flex-end;">
                <a href="/line/definitions" class="swe-btn-secondary">Reset</a>
                <button type="submit" class="swe-btn-primary">Apply</button>
            </div>
        </form>
        {{#hasTagCloud}}
        <div style="margin-top: var(--space-md); display: flex; flex-wrap: wrap; gap: var(--space-xs);">
            <span class="swe-mute" style="font-size: 12px; align-self: center; margin-right: var(--space-xs);">Tag cloud:</span>
            {{#tagCloud}}
            <a href="/line/definitions?tag={{tag}}"
               class="swe-tag swe-tag-{{colorClass}}"
               title="{{count}} 개 라인"
               style="text-decoration: none;">
                {{tag}} <span class="swe-mute" style="font-size: 10px;">{{count}}</span>
            </a>
            {{/tagCloud}}
        </div>
        {{/hasTagCloud}}
    </div>

    <div class="swe-card" style="padding: 0;">
        <table class="swe-table">
            <thead>
            <tr>
                <th>Line Name</th>
                <th>Tags</th>
                <th>Description</th>
                <th>Version</th>
                <th>Created</th>
                <th class="swe-text-right">Action</th>
            </tr>
            </thead>
            <tbody>
            {{#definitions}}
            <tr>
                <td><strong>{{definitionNm}}</strong></td>
                <td>
                    {{#tagViews}}
                    <a href="/line/definitions?tag={{tag}}" class="swe-tag swe-tag-{{colorClass}}" style="text-decoration:none; margin-right: 4px;">{{tag}}</a>
                    {{/tagViews}}
                </td>
                <td class="swe-mute">{{#description}}{{description}}{{/description}}{{^description}}—{{/description}}</td>
                <td>v{{versionNo}}</td>
                <td class="swe-mute">{{#regDt}}{{regDt}}{{/regDt}}{{^regDt}}—{{/regDt}}</td>
                <td class="swe-text-right">
                    <a href="/line/definitions/{{id}}" class="swe-btn-tertiary swe-btn-sm">Preview</a>
                    <a href="/line/builder?id={{id}}" class="swe-btn-tertiary swe-btn-sm">Edit</a>
                </td>
            </tr>
            {{/definitions}}
            {{^definitions}}
            <tr>
                <td colspan="6" style="text-align: center; padding: var(--space-section) 0; color: var(--mute);">
                    {{#filterTag}}태그 "{{filterTag}}" 일치 없음{{/filterTag}}{{^filterTag}}{{#filterName}}이름 "{{filterName}}" 일치 없음{{/filterName}}{{^filterName}}아직 라인이 없습니다. <a href="/line/builder" class="swe-ink">Builder</a>에서 새 라인을 만들어보세요.{{/filterName}}{{/filterTag}}
                </td>
            </tr>
            {{/definitions}}
            </tbody>
        </table>
        {{> _pagination }}
    </div>

</div>

<!-- #193 — Import 모달 (JSON 업로드 → POST /api/line/definitions/import) -->
<div class="swe-modal-backdrop" id="import-backdrop" style="display:none;" onclick="closeImportModal()"></div>
<div class="swe-modal" id="import-modal" role="dialog" aria-modal="true" aria-labelledby="import-title"
     style="display:none; position:fixed; top:50%; left:50%; transform:translate(-50%, -50%);
            width: 480px; max-width: 90vw; background: var(--surface); border: 1px solid var(--hairline);
            border-radius: var(--radius-lg); padding: var(--space-lg); z-index: 1600;">
    <div class="swe-flex-between swe-mb-md">
        <h3 id="import-title" class="swe-heading-md" style="margin:0;">Import line definition</h3>
        <button type="button" class="swe-btn-tertiary swe-btn-sm" onclick="closeImportModal()">✕</button>
    </div>
    <div class="swe-stack" style="gap: var(--space-md);">
        <div>
            <label for="import-file">JSON 파일</label>
            <input type="file" id="import-file" class="swe-input" accept=".json,application/json">
            <div class="swe-mute" style="font-size: 11px; margin-top: 4px;">
                <code>/line/definitions/{id}</code> 페이지의 <strong>⬇ Export</strong> 로 받은 JSON.
            </div>
        </div>
        <div>
            <label for="import-conflict">이름 충돌 정책</label>
            <select id="import-conflict" class="swe-input">
                <option value="newVersion" selected>newVersion — 동일 이름이면 새 버전으로 추가 (기본)</option>
                <option value="rename">rename — "이름 (1)", "(2)" … suffix로 새 이름</option>
                <option value="reject">reject — 동일 이름 있으면 거부 (4xx)</option>
            </select>
        </div>
        <div id="import-result" class="swe-mute" style="font-size: 12px; min-height: 18px;"></div>
    </div>
    <div class="swe-flex-between" style="margin-top: var(--space-lg);">
        <button type="button" class="swe-btn-tertiary" onclick="closeImportModal()">Cancel</button>
        <button type="button" class="swe-btn-primary" id="import-submit" onclick="submitImport()">Import</button>
    </div>
</div>

<script>
function openImportModal() {
    document.getElementById('import-backdrop').style.display = 'block';
    document.getElementById('import-modal').style.display = 'block';
    document.getElementById('import-result').textContent = '';
    document.getElementById('import-result').style.color = '';
}
function closeImportModal() {
    document.getElementById('import-backdrop').style.display = 'none';
    document.getElementById('import-modal').style.display = 'none';
}
async function submitImport() {
    const fileEl = document.getElementById('import-file');
    const resultEl = document.getElementById('import-result');
    const submitBtn = document.getElementById('import-submit');
    if (!fileEl.files || fileEl.files.length === 0) {
        resultEl.textContent = 'JSON 파일을 선택하세요.';
        resultEl.style.color = 'var(--accent-pink)';
        return;
    }
    const file = fileEl.files[0];
    let payload;
    try {
        payload = JSON.parse(await file.text());
    } catch (e) {
        resultEl.textContent = 'JSON 파싱 실패: ' + e.message;
        resultEl.style.color = 'var(--accent-pink)';
        return;
    }
    const policy = document.getElementById('import-conflict').value;
    submitBtn.disabled = true;
    resultEl.textContent = 'Importing…';
    resultEl.style.color = 'var(--mute)';
    try {
        const res = await fetch('/api/line/definitions/import?onConflict=' + encodeURIComponent(policy), {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
        });
        if (res.ok) {
            const j = await res.json();
            resultEl.textContent = '[OK] id=' + j.definitionId + ' · nm=' + j.definitionNm
                + ' · policy=' + j.appliedPolicy;
            resultEl.style.color = 'var(--accent-green, #1f883d)';
            // 1.5초 후 리스트 새로고침 (새 정의 노출)
            setTimeout(() => window.location.reload(), 1500);
        } else {
            const j = await res.json().catch(() => ({}));
            resultEl.textContent = '[FAIL] ' + (j.errorCode ? '[' + j.errorCode + '] ' : '')
                + (j.message || res.statusText);
            resultEl.style.color = 'var(--accent-pink)';
        }
    } catch (e) {
        resultEl.textContent = '[FAIL] ' + e.message;
        resultEl.style.color = 'var(--accent-pink)';
    } finally {
        submitBtn.disabled = false;
    }
}
// Esc로 닫기
document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape' && document.getElementById('import-modal').style.display === 'block') {
        closeImportModal();
    }
});
</script>

</body>
</html>
