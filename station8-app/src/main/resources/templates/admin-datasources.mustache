<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <title>DataSources — Station8</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    <link rel="stylesheet" href="/css/design.css">
</head>
<body>
{{> _nav }}

<div class="swe-container" style="padding-top: var(--space-xxl); padding-bottom: var(--space-section);">

    <div class="swe-flex-between swe-mb-xl">
        <div>
            <h1 class="swe-display-lg" style="margin: 0;">DataSources</h1>
            <p class="swe-body-md swe-mute" style="margin: var(--space-sm) 0 0;">
                등록된 DataSource 진단 + 동적 등록/수정/삭제. PRIMARY와 STATIC(application.properties)은 Test connection만, DYNAMIC만 수정 가능.
            </p>
        </div>
        <a href="/admin/datasources/new" class="swe-btn-primary">+ New DataSource</a>
    </div>

    {{#testMsg}}
    <div class="swe-card swe-mb-xl" style="padding: var(--space-md) var(--space-lg); border-left: 4px solid {{#testOk}}var(--accent-green){{/testOk}}{{^testOk}}var(--accent-pink){{/testOk}};">
        <code style="color: var(--ink); font-size: 0.95em;">{{testMsg}}</code>
    </div>
    {{/testMsg}}

    <!-- 통계 -->
    <div class="swe-grid swe-grid-3 swe-mb-xl">
        <div class="swe-stat-card">
            <div class="swe-stat-label" style="color: var(--accent-green);">Healthy</div>
            <div class="swe-stat-value">{{healthyCount}}</div>
        </div>
        <div class="swe-stat-card">
            <div class="swe-stat-label" style="color: var(--accent-pink);">Unhealthy</div>
            <div class="swe-stat-value">{{unhealthyCount}}</div>
        </div>
        <div class="swe-stat-card">
            <div class="swe-stat-label">Total</div>
            <div class="swe-stat-value">{{totalCount}}</div>
        </div>
    </div>

    <!-- 테이블 -->
    <div class="swe-card" style="padding: 0;">
        <table class="swe-table">
            <thead>
            <tr>
                <th>Name</th>
                <th>Source</th>
                <th>URL</th>
                <th>User</th>
                <th>Dialect</th>
                <th>Health</th>
                <th>Pool (a / i / t)</th>
                <th class="swe-text-right">Actions</th>
            </tr>
            </thead>
            <tbody>
            {{#datasources}}
            <tr>
                <td><strong>{{name}}</strong></td>
                <td>
                    {{#isPrimary}}<span class="swe-badge" style="background: var(--accent-pink); color: var(--on-accent);">PRIMARY</span>{{/isPrimary}}
                    {{#isStatic}}<span class="swe-badge swe-badge-secondary">STATIC</span>{{/isStatic}}
                    {{#isDynamic}}<span class="swe-badge swe-badge-info">DYNAMIC</span>{{/isDynamic}}
                </td>
                <td class="swe-id-cell" title="{{url}}">
                    <span style="display:inline-flex;align-items:center;gap:var(--space-xs);width:100%;">
                        <span style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap;flex:1;">{{url}}</span>
                        <button type="button" class="swe-copy-btn" data-copy="{{url}}" title="URL 복사" aria-label="Copy URL">
                            <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                                <rect x="5" y="5" width="9" height="9" rx="1.5" stroke="currentColor" stroke-width="1.4"/>
                                <path d="M3 11 L3 3 C3 2.4 3.4 2 4 2 L11 2" stroke="currentColor" stroke-width="1.4" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                        </button>
                    </span>
                </td>
                <td class="swe-mute">{{username}}</td>
                <td><span class="swe-keycap">{{dialect}}</span></td>
                <td>
                    {{#enabled}}
                        {{#healthy}}<span class="swe-badge swe-badge-success">Healthy</span>{{/healthy}}
                        {{^healthy}}<span class="swe-badge swe-badge-danger" title="{{errorMsg}}">Down</span>{{/healthy}}
                    {{/enabled}}
                    {{^enabled}}<span class="swe-badge swe-badge-warning">Disabled</span>{{/enabled}}
                </td>
                <td class="swe-mute">
                    {{#hasPoolStats}}{{activeConn}} / {{idleConn}} / {{totalConn}}{{/hasPoolStats}}
                    {{^hasPoolStats}}—{{/hasPoolStats}}
                </td>
                <td class="swe-actions">
                    {{#enabled}}
                    <form action="/admin/datasources/{{name}}/test" method="post" style="display:inline;">
                        {{> _csrf}}
                        <button type="submit" class="swe-btn-tertiary swe-btn-sm">Test</button>
                    </form>
                    {{/enabled}}
                    {{#isDynamic}}
                    <a href="/admin/datasources/{{name}}/edit" class="swe-btn-tertiary swe-btn-sm">Edit</a>
                    <form action="/admin/datasources/{{name}}/toggle-enabled" method="post" style="display:inline;">
                        {{> _csrf}}
                        <button type="submit" class="swe-btn-tertiary swe-btn-sm">{{#enabled}}Disable{{/enabled}}{{^enabled}}Enable{{/enabled}}</button>
                    </form>
                    <form action="/admin/datasources/{{name}}/delete" method="post" style="display:inline;" onsubmit="return confirm('Delete DataSource &quot;{{name}}&quot;?');">
                        {{> _csrf}}
                        <button type="submit" class="swe-btn-tertiary swe-btn-sm swe-btn-danger">Delete</button>
                    </form>
                    {{/isDynamic}}
                </td>
            </tr>
            {{/datasources}}
            {{^datasources}}
            <tr>
                <td colspan="8" style="text-align: center; padding: var(--space-section) 0; color: var(--mute);">
                    등록된 DataSource가 없습니다. <strong style="color: var(--ink);">+ New DataSource</strong> 클릭 또는
                    <code>application.properties</code>에서 <code>station8.datasources.&lt;name&gt;.url</code>로 정적 선언하세요.
                </td>
            </tr>
            {{/datasources}}
            </tbody>
        </table>
    </div>

</div>
<script>
    // #235 — URL 복사 버튼 (data-copy 위임)
    document.addEventListener('click', function (e) {
        var btn = e.target.closest('.swe-copy-btn');
        if (!btn) return;
        var text = btn.dataset.copy;
        if (!text) return;
        if (navigator.clipboard && navigator.clipboard.writeText) {
            navigator.clipboard.writeText(text).then(function () { flashCopied(btn); });
        } else {
            // 옛 브라우저 fallback — textarea + execCommand
            var ta = document.createElement('textarea');
            ta.value = text;
            ta.style.position = 'fixed';
            ta.style.opacity = '0';
            document.body.appendChild(ta);
            ta.select();
            try { document.execCommand('copy'); flashCopied(btn); } finally { document.body.removeChild(ta); }
        }
    });
    function flashCopied(btn) {
        var prev = btn.getAttribute('title');
        btn.setAttribute('title', 'Copied!');
        btn.classList.add('copied');
        setTimeout(function () {
            btn.setAttribute('title', prev || 'URL 복사');
            btn.classList.remove('copied');
        }, 1200);
    }
</script>
</body>
</html>
