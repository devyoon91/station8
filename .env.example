# Station8 환경변수 템플릿
# ============================================================
# 사용법:
#   cp .env.example .env
#   <편집> 비밀번호 / URL 등 채우기
#   - 로컬 jar 실행:  set -a; source .env; set +a; java -jar station8-app/build/libs/station8-app.jar
#   - docker compose: cp .env.example docker/.env  (compose가 자동 로드)
#
# .env는 .gitignore에 등록되어 커밋되지 않음.
# ============================================================

# --- 초기 ADMIN 계정 (#121) -----------------------------------
# 비워두면 첫 부팅(DB 빈) 시 랜덤 비밀번호 자동 생성 + 콘솔 1회 출력.
# 명시하면 그 비밀번호로 시드 (정책: 8자+ 숫자+ 특수문자+).
STATION8_INITIAL_ADMIN_USERNAME=admin
STATION8_INITIAL_ADMIN_PASSWORD=

# --- Spring Profile -----------------------------------------
# default / docker / demo 조합 가능. 컴마 분리.
# - docker: docker-compose 환경
# - demo: DemoSeedRunner가 샘플 DAG + 스케줄 자동 시드
# SPRING_PROFILES_ACTIVE=docker,demo

# --- Primary DataSource (엔진 상태 DB) ----------------------
# 본 프로파일 default는 H2 in-memory. 운영에서는 MariaDB / Oracle 지정.
# SPRING_DATASOURCE_URL=jdbc:mariadb://localhost:3307/workflow?useSSL=false&serverTimezone=UTC
# SPRING_DATASOURCE_USERNAME=wfuser
# SPRING_DATASOURCE_PASSWORD=wfpw

# --- Secondary DataSource 비밀번호 (#108) -------------------
# application.properties의 station8.datasources.<name>.password=${...} 치환에 사용.
# 사용자 정의 — 본 템플릿엔 예시 placeholder만.
# DB_SOURCE_ORACLE_PASSWORD=
# DB_TARGET_MART_PASSWORD=

# --- DLQ 웹훅 알림 ------------------------------------------
# 비어있으면 콘솔 로그로 대체. Slack incoming webhook 등.
# ENGINE_DLQ_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ

# --- Plugin 로더 (#102 / #103) -------------------------------
# 활성화 시 부팅 + /admin/plugins/reload에서 plugins/ 스캔.
# ENGINE_PLUGINS_ENABLED=true
# ENGINE_PLUGINS_DIR=plugins

# --- JVM 옵션 -----------------------------------------------
# 컨테이너 메모리에 맞춰 조정.
# JAVA_OPTS=-Xms256m -Xmx512m
